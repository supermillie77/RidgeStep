<?xml version="1.0" encoding="utf-8"?>
<!-- Page 2: Plan your route -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Illustration -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="55"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_gravity="bottom"
            android:src="@drawable/ic_onboard_mountains"
            android:scaleType="fitXY"
            android:alpha="0.5"/>

        <!-- Route card, tilted -2.5° -->
        <androidx.cardview.widget.CardView
            android:layout_width="250dp"
            android:layout_height="168dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:rotation="-2.5"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/ob_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Hill name header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ben Nevis"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tourist Path"
                    android:textSize="11sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginBottom="12dp"/>

                <!-- Route A→B bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Start pin -->
                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="P"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_onboard_btn_primary"/>

                    <!-- Dashed line (series of dots) -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@color/ob_route_blue"/>

                    <!-- Summit marker -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▲"
                        android:textColor="@color/nav_orange"
                        android:textSize="22sp"/>
                </LinearLayout>

                <!-- Labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Visitor Centre"
                        android:textSize="9sp"
                        android:textColor="@color/ob_subtitle"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Summit"
                        android:textSize="9sp"
                        android:textColor="@color/ob_subtitle"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="10dp"
                    android:background="#EEEAE3"/>

                <!-- Stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="8.4 km" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/ob_headline"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Distance" android:textSize="9sp" android:textColor="@color/ob_subtitle"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="850 m" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/ob_headline"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ascent" android:textSize="9sp" android:textColor="@color/ob_subtitle"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="4h 30m" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/ob_headline"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Est. time" android:textSize="9sp" android:textColor="@color/ob_subtitle"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Floating car park chip, tilted +3° -->
        <androidx.cardview.widget.CardView
            android:layout_width="200dp"
            android:layout_height="44dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="22dp"
            android:layout_marginBottom="20dp"
            android:rotation="3"
            app:cardCornerRadius="22dp"
            app:cardElevation="5dp"
            app:cardBackgroundColor="@color/ob_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🅿" android:textSize="14sp" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="4 car parks found nearby"
                    android:textSize="11sp" android:textColor="@color/ob_headline"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <!-- Text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="45"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plan your route"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"
            android:lineSpacingMultiplier="1.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Search for a hill, pick your car park, and get a real footpath route with distance and ascent"
            android:textSize="15sp"
            android:textColor="@color/ob_subtitle"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

</LinearLayout>
