<?xml version="1.0" encoding="utf-8"?>
<!-- Page 3: From car park to summit — route schematic -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Hero: vertical route schematic (58%) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="58"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <!-- Vertical route line (centre) -->
        <View
            android:id="@+id/routeLine"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:layout_centerHorizontal="true"
            android:background="#FF6B35"
            android:alpha="0.5"/>

        <!-- Summit top -->
        <LinearLayout
            android:id="@+id/summitBlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_alignParentTop="true"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@color/ob_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲"
                android:textColor="#FF6D00"
                android:textSize="40sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ben Nevis"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/ob_headline"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1,345 m summit"
                android:textSize="10sp"
                android:textColor="#FF6B35"/>
        </LinearLayout>

        <!-- Car park bottom -->
        <LinearLayout
            android:id="@+id/parkBlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@color/ob_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp">
            <TextView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="P"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FF6B35"
                android:gravity="center"
                android:background="@drawable/bg_onboard_btn_primary"
                android:alpha="0.3"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Visitor Centre car park"
                android:textSize="11sp"
                android:textColor="@color/ob_subtitle"/>
        </LinearLayout>

        <!-- Stat callouts — right of the line -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="44dp"
            android:layout_toEndOf="@id/routeLine"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8.4 km"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ob_headline"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="distance"
                android:textSize="10sp"
                android:textColor="@color/ob_subtitle"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="↑ 850 m"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ob_headline"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ascent"
                android:textSize="10sp"
                android:textColor="@color/ob_subtitle"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="4h 30m"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ob_headline"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="est. time"
                android:textSize="10sp"
                android:textColor="@color/ob_subtitle"/>
        </LinearLayout>

        <!-- Car park chip — left of the line -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_centerHorizontal="true"
            android:layout_marginEnd="44dp"
            android:layout_toStartOf="@id/routeLine"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#127359;"
                android:textSize="12sp"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 car parks\nnearby"
                android:textSize="9sp"
                android:textColor="@color/ob_subtitle"/>
        </LinearLayout>

    </RelativeLayout>

    <!-- Text (42%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="42"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="16dp">

        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:background="#FF6B35"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plan your route"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"
            android:lineSpacingMultiplier="1.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Search for a hill, pick your car park, and get a real footpath route with distance and ascent"
            android:textSize="14sp"
            android:textColor="@color/ob_subtitle"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

</LinearLayout>
