<?xml version="1.0" encoding="utf-8"?>
<!-- Page 6: Your controls — clean reference, dark theme -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Header (18%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="18"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="24dp">

        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:background="#FF6B35"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your controls"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Six buttons — expand on first use, then tuck to icons"
            android:textSize="12sp"
            android:textColor="@color/ob_subtitle"
            android:layout_marginTop="4dp"
            android:lineSpacingMultiplier="1.3"/>

    </LinearLayout>

    <!-- Controls list (82%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="82"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp">

        <!-- Find a hill -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="12dp"
            android:layout_marginBottom="2dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_search"
                android:padding="8dp"
                android:background="@color/ob_background"
                android:contentDescription="Find a hill"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Find a hill"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Search any summit, pick a car park and get a real footpath route"
                    android:textSize="11sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginTop="1dp"
                    android:lineSpacingMultiplier="1.2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Hills near me -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="12dp"
            android:layout_marginBottom="2dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:padding="8dp"
                android:background="@color/ob_background"
                android:contentDescription="Hills near me"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hills near me"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See the closest summits to your location with distance and time estimates"
                    android:textSize="11sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginTop="1dp"
                    android:lineSpacingMultiplier="1.2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Re-centre -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="12dp"
            android:layout_marginBottom="2dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_my_location"
                android:padding="8dp"
                android:background="@color/ob_background"
                android:contentDescription="Re-centre map"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Re-centre map"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jump the map back to your GPS position at any time"
                    android:textSize="11sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginTop="1dp"
                    android:lineSpacingMultiplier="1.2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Voice guide -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="12dp"
            android:layout_marginBottom="2dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:padding="8dp"
                android:background="@color/ob_background"
                android:contentDescription="Voice guide"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice guide"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Turn-by-turn audio directions — tap to mute when you need quiet"
                    android:textSize="11sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginTop="1dp"
                    android:lineSpacingMultiplier="1.2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Stats & info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="12dp"
            android:layout_marginBottom="2dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_info_details"
                android:padding="8dp"
                android:background="@color/ob_background"
                android:contentDescription="Stats and info"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stats &amp; info"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance, ascent and difficulty grade at a glance"
                    android:textSize="11sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginTop="1dp"
                    android:lineSpacingMultiplier="1.2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Tap the map -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="12dp">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="&#128204;"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@color/ob_background"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap the map"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drop pins for start and destination — the app finds the footpath between them"
                    android:textSize="11sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginTop="1dp"
                    android:lineSpacingMultiplier="1.2"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
