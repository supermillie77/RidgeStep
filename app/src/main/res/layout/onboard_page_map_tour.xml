<?xml version="1.0" encoding="utf-8"?>
<!-- Page 6: Your controls — clean reference, dark theme -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Header (22%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="22"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="28dp">

        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:background="#FF6B35"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your controls"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Three buttons in the corner — they expand on first use, then tuck to icons"
            android:textSize="13sp"
            android:textColor="@color/ob_subtitle"
            android:layout_marginTop="6dp"
            android:lineSpacingMultiplier="1.3"/>

    </LinearLayout>

    <!-- Controls list (78%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="78"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <!-- Find a hill -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="16dp"
            android:layout_marginBottom="3dp">
            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="&#128269;"
                android:textSize="22sp"
                android:gravity="center"
                android:background="@color/ob_background"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Find a hill"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Search any summit, pick a car park and get a real footpath route"
                    android:textSize="12sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginTop="2dp"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Voice guide -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="16dp"
            android:layout_marginBottom="3dp">
            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="&#128266;"
                android:textSize="22sp"
                android:gravity="center"
                android:background="@color/ob_background"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice guide"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Turn-by-turn audio directions — tap to mute when you need quiet"
                    android:textSize="12sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginTop="2dp"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Stats & info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="16dp"
            android:layout_marginBottom="3dp">
            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="&#8505;"
                android:textSize="22sp"
                android:textColor="@color/ob_headline"
                android:gravity="center"
                android:background="@color/ob_background"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stats &amp; info"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance, ascent and difficulty grade at a glance"
                    android:textSize="12sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginTop="2dp"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Tap the map -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="16dp">
            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="&#128204;"
                android:textSize="22sp"
                android:gravity="center"
                android:background="@color/ob_background"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap the map"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drop pins for start and destination — the app finds the footpath between them"
                    android:textSize="12sp"
                    android:textColor="@color/ob_subtitle"
                    android:layout_marginTop="2dp"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
