<?xml version="1.0" encoding="utf-8"?>
<!-- Page 6: Your controls — full reference of every map button and gesture -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:background="#FF6B35"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your controls"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nine buttons plus gestures — expand on first use, then tuck to icons"
            android:textSize="12sp"
            android:textColor="@color/ob_subtitle"
            android:layout_marginTop="4dp"
            android:lineSpacingMultiplier="1.3"/>

    </LinearLayout>

    <!-- Scrollable controls list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadingEdgeLength="12dp"
        android:requiresFadingEdge="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- Find a hill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="12dp"
                android:layout_marginBottom="2dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:padding="8dp"
                    android:background="@color/ob_background"
                    android:contentDescription="Find a hill"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find a hill  (bottom-right)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Search any summit, pick a car park and get a real footpath route"
                        android:textSize="11sp"
                        android:textColor="@color/ob_subtitle"
                        android:layout_marginTop="1dp"
                        android:lineSpacingMultiplier="1.2"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Hills near me -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="12dp"
                android:layout_marginBottom="2dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:padding="8dp"
                    android:background="@color/ob_background"
                    android:contentDescription="Hills near me"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hills near me  (bottom-left)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Closest summits and walks &amp; places within 5–25 miles, with time estimates"
                        android:textSize="11sp"
                        android:textColor="@color/ob_subtitle"
                        android:layout_marginTop="1dp"
                        android:lineSpacingMultiplier="1.2"/>
                </LinearLayout>
            </LinearLayout>

            <!-- My log -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="12dp"
                android:layout_marginBottom="2dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:padding="8dp"
                    android:background="@color/ob_background"
                    android:contentDescription="My log"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My log  (bottom-left)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Track your completed summits with progress bars per category (Munros, Corbetts, etc.) and share your location"
                        android:textSize="11sp"
                        android:textColor="@color/ob_subtitle"
                        android:layout_marginTop="1dp"
                        android:lineSpacingMultiplier="1.2"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Re-centre -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="12dp"
                android:layout_marginBottom="2dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_my_location"
                    android:padding="8dp"
                    android:background="@color/ob_background"
                    android:contentDescription="Re-centre map"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Re-centre map  (bottom-left)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Appears when you pan away — tap to snap the map back to your GPS position"
                        android:textSize="11sp"
                        android:textColor="@color/ob_subtitle"
                        android:layout_marginTop="1dp"
                        android:lineSpacingMultiplier="1.2"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Voice guide -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="12dp"
                android:layout_marginBottom="2dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    android:padding="8dp"
                    android:background="@color/ob_background"
                    android:contentDescription="Voice guide"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Voice guide  (bottom-right)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Turn-by-turn audio directions — tap to mute or unmute"
                        android:textSize="11sp"
                        android:textColor="@color/ob_subtitle"
                        android:layout_marginTop="1dp"
                        android:lineSpacingMultiplier="1.2"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Stats & info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="12dp"
                android:layout_marginBottom="2dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:padding="8dp"
                    android:background="@color/ob_background"
                    android:contentDescription="Stats and info"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stats &amp; info  (bottom-right)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distance, ascent, difficulty grade and live navigation stats"
                        android:textSize="11sp"
                        android:textColor="@color/ob_subtitle"
                        android:layout_marginTop="1dp"
                        android:lineSpacingMultiplier="1.2"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Compass -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="12dp"
                android:layout_marginBottom="2dp">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="&#x1F9ED;"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@color/ob_background"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Compass  (top-left)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live magnetic compass — always shows which way is north"
                        android:textSize="11sp"
                        android:textColor="@color/ob_subtitle"
                        android:layout_marginTop="1dp"
                        android:lineSpacingMultiplier="1.2"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Orange pin -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="12dp"
                android:layout_marginBottom="2dp">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="&#128205;"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@color/ob_background"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your location pin"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Orange teardrop showing your GPS position. When you move: the sharp POINT rotates to face your direction of travel; an orange cone radiates forward from the point; and the compass direction (N, NE, E&#8230;) is shown inside the round head of the pin."
                        android:textSize="11sp"
                        android:textColor="@color/ob_subtitle"
                        android:layout_marginTop="1dp"
                        android:lineSpacingMultiplier="1.2"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Long-press summit -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="12dp"
                android:layout_marginBottom="2dp">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="&#9651;"
                    android:textSize="22sp"
                    android:textColor="#FF6D00"
                    android:gravity="center"
                    android:background="@color/ob_background"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Long-press a summit"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shows summit info: elevation, distance from you, estimated time. Tap &#8220;Mark as climbed&#8221; to add it to your log"
                        android:textSize="11sp"
                        android:textColor="@color/ob_subtitle"
                        android:layout_marginTop="1dp"
                        android:lineSpacingMultiplier="1.2"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Tap the map -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="12dp">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="&#128204;"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@color/ob_background"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap the map"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drop pins for start and destination — the app finds the footpath between them"
                        android:textSize="11sp"
                        android:textColor="@color/ob_subtitle"
                        android:layout_marginTop="1dp"
                        android:lineSpacingMultiplier="1.2"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
