<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0D1B2A">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="#1E3347"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hills near you"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#E8EDF2"/>

        <TextView
            android:id="@+id/nearbySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Closest summits from your location"
            android:textSize="13sp"
            android:textColor="#7B95A9"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E3347"/>

    <!-- Hills list — rows added programmatically -->
    <LinearLayout
        android:id="@+id/nearbyHillsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <!-- Bottom padding -->
    <View
        android:layout_width="match_parent"
        android:layout_height="24dp"/>

</LinearLayout>
