<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0D1B2A">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="#1E3347"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hills near you"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#E8EDF2"/>

        <TextView
            android:id="@+id/nearbySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Closest summits from your location"
            android:textSize="13sp"
            android:textColor="#7B95A9"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Radius chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/radiusChipsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>

    </HorizontalScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E3347"/>

    <!-- Hills list in a scroll view so long lists don't clip -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="480dp"
        android:fadeScrollbars="true">

        <LinearLayout
            android:id="@+id/nearbyHillsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

    <!-- Bottom padding -->
    <View
        android:layout_width="match_parent"
        android:layout_height="24dp"/>

</LinearLayout>
