<?xml version="1.0" encoding="utf-8"?>
<!-- Page 4: Know the terrain — full-width elevation profile -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Hero: elevation profile (55%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="55"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- Profile header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Elevation profile"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/ob_subtitle"
                android:letterSpacing="0.06"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲ 1,345 m total ascent"
                android:textSize="11sp"
                android:textColor="#FF6B35"/>
        </LinearLayout>

        <!-- The elevation profile SVG -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/ic_elevation_profile"
            android:scaleType="fitXY"/>

        <!-- Axis labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Start" android:textSize="9sp" android:textColor="@color/ob_subtitle"/>
            <android.widget.Space android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="8.4 km" android:textSize="9sp" android:textColor="@color/ob_subtitle"/>
        </LinearLayout>

        <!-- Three stat boxes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@color/ob_surface"
                android:paddingTop="10dp" android:paddingBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="850 m" android:textSize="18sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="↑ Ascent" android:textSize="9sp" android:textColor="@color/ob_subtitle"/>
            </LinearLayout>

            <View android:layout_width="2dp" android:layout_height="match_parent"
                android:background="@color/ob_background"/>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@color/ob_surface"
                android:paddingTop="10dp" android:paddingBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="850 m" android:textSize="18sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="↓ Descent" android:textSize="9sp" android:textColor="@color/ob_subtitle"/>
            </LinearLayout>

            <View android:layout_width="2dp" android:layout_height="match_parent"
                android:background="@color/ob_background"/>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@color/ob_surface"
                android:paddingTop="10dp" android:paddingBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="30°" android:textSize="18sp" android:textStyle="bold"
                    android:textColor="#FF6B35"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Max slope" android:textSize="9sp" android:textColor="@color/ob_subtitle"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Difficulty chip -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:paddingStart="12dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginTop="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="&#128992; " android:textSize="12sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Strenuous hillwalk"
                android:textSize="12sp" android:textStyle="bold" android:textColor="#FF8C00"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Text (45%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="45"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="16dp">

        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:background="#FF6B35"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Know the terrain"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"
            android:lineSpacingMultiplier="1.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Elevation gain, max gradient and a safety grade before you take a single step"
            android:textSize="14sp"
            android:textColor="@color/ob_subtitle"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

</LinearLayout>
