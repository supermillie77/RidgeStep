<?xml version="1.0" encoding="utf-8"?>
<!-- Page 5: Navigate with confidence — turn card + progress -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Hero: navigation UI mock (55%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="55"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp">

        <!-- Turn instruction block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/ob_surface"
            android:padding="16dp">

            <!-- Direction arrow -->
            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:text="↗"
                android:textSize="26sp"
                android:textColor="#FF6B35"
                android:gravity="center"
                android:background="@color/ob_background"
                android:layout_marginEnd="16dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bear left onto the ridge path"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"
                    android:lineSpacingMultiplier="1.2"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="in 200 m"
                    android:textSize="12sp"
                    android:textColor="#FF6B35"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Route progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/ob_surface"
            android:padding="14dp"
            android:layout_marginTop="2dp">

            <!-- Progress bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:orientation="horizontal">
                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="42"
                    android:background="#FF6B35"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="58"
                    android:background="@color/ob_divider"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="3.5 km done" android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
                <android.widget.Space android:layout_width="0dp" android:layout_height="0dp"
                    android:layout_weight="1"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="4.9 km to go" android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Weather + voice strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <!-- Weather -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/ob_surface"
                android:padding="10dp"
                android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="&#9728; " android:textSize="16sp"
                    android:layout_marginEnd="6dp"/>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Clear  12°C"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Good for hiking"
                        android:textSize="9sp" android:textColor="@color/ob_subtitle"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Voice -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FF6B35"
                android:padding="10dp"
                android:layout_marginStart="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="&#128266;"
                    android:textSize="16sp" android:layout_marginEnd="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Voice on"
                    android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Text (45%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="45"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="16dp">

        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:background="#FF6B35"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Navigate with confidence"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"
            android:lineSpacingMultiplier="1.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Voice-guided turn-by-turn directions and live weather alerts keep you safe on the mountain"
            android:textSize="14sp"
            android:textColor="@color/ob_subtitle"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

</LinearLayout>
