<?xml version="1.0" encoding="utf-8"?>
<!-- Page 2: Hill categories colour legend -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Illustration: categories card -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="55"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_gravity="bottom"
            android:src="@drawable/ic_onboard_mountains"
            android:scaleType="fitXY"
            android:alpha="0.5"/>

        <!-- Main categories card, tilted -2° -->
        <androidx.cardview.widget.CardView
            android:layout_width="268dp"
            android:layout_height="210dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:rotation="-2"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/ob_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hill categories"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/ob_headline"
                    android:layout_marginBottom="10dp"/>

                <!-- Munro row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="7dp">
                    <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#FF6D00" android:textSize="14sp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Munro" android:textSize="11sp" android:textStyle="bold"
                            android:textColor="@color/ob_headline"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Scotland  ≥ 914 m (3,000 ft)" android:textSize="9sp"
                            android:textColor="@color/ob_subtitle"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="282" android:textSize="10sp" android:textColor="@color/ob_subtitle"/>
                </LinearLayout>

                <!-- Corbett row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="7dp">
                    <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#E53935" android:textSize="14sp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Corbett" android:textSize="11sp" android:textStyle="bold"
                            android:textColor="@color/ob_headline"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Scotland  762 – 914 m" android:textSize="9sp"
                            android:textColor="@color/ob_subtitle"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="222" android:textSize="10sp" android:textColor="@color/ob_subtitle"/>
                </LinearLayout>

                <!-- Fiona row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="7dp">
                    <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#FF4081" android:textSize="14sp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fiona" android:textSize="11sp" android:textStyle="bold"
                            android:textColor="@color/ob_headline"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Scotland  762 – 914 m (all tops)" android:textSize="9sp"
                            android:textColor="@color/ob_subtitle"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Wainwright row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="7dp">
                    <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#1E88E5" android:textSize="14sp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Wainwright" android:textSize="11sp" android:textStyle="bold"
                            android:textColor="@color/ob_headline"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Lake District  214 fells" android:textSize="9sp"
                            android:textColor="@color/ob_subtitle"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="214" android:textSize="10sp" android:textColor="@color/ob_subtitle"/>
                </LinearLayout>

                <!-- Hewitt row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="7dp">
                    <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#00ACC1" android:textSize="14sp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Hewitt" android:textSize="11sp" android:textStyle="bold"
                            android:textColor="@color/ob_headline"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="England / Wales  ≥ 610 m" android:textSize="9sp"
                            android:textColor="@color/ob_subtitle"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#EEEAE3" android:layout_marginBottom="6dp"/>

                <!-- More categories row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#43A047" android:textSize="11sp"
                        android:layout_marginEnd="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Donald" android:textSize="9sp" android:textColor="@color/ob_subtitle"
                        android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#26A69A" android:textSize="11sp"
                        android:layout_marginEnd="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Island" android:textSize="9sp" android:textColor="@color/ob_subtitle"
                        android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#FFD600" android:textSize="11sp"
                        android:layout_marginEnd="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sub 2000" android:textSize="9sp" android:textColor="@color/ob_subtitle"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <!-- Text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="45"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find your challenge"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"
            android:lineSpacingMultiplier="1.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="From towering Munros to island summits and classic Wainwrights — every category has its own colour on the map"
            android:textSize="15sp"
            android:textColor="@color/ob_subtitle"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

</LinearLayout>
