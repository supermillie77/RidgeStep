<?xml version="1.0" encoding="utf-8"?>
<!-- Page 2: Nine categories — leaderboard style list -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Header (20%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="20"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="28dp"
        android:paddingBottom="4dp">

        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:background="#FF6B35"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nine categories"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find your challenge — each has its own colour on the map"
            android:textSize="13sp"
            android:textColor="@color/ob_subtitle"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

    <!-- Category list (80%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="80"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <!-- Munro -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <View android:layout_width="4dp" android:layout_height="match_parent"
                android:background="#FF6D00" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲ " android:textColor="#FF6D00" android:textSize="13sp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Munro" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Scotland  ≥ 914 m" android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="282" android:textSize="13sp" android:textStyle="bold"
                android:textColor="#FF6D00"/>
        </LinearLayout>

        <!-- Corbett -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <View android:layout_width="4dp" android:layout_height="match_parent"
                android:background="#E53935" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲ " android:textColor="#E53935" android:textSize="13sp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Corbett" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Scotland  762 – 914 m" android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="222" android:textSize="13sp" android:textStyle="bold"
                android:textColor="#E53935"/>
        </LinearLayout>

        <!-- Graham -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <View android:layout_width="4dp" android:layout_height="match_parent"
                android:background="#AB47BC" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲ " android:textColor="#AB47BC" android:textSize="13sp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Graham" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Scotland  610 – 762 m" android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="224" android:textSize="13sp" android:textStyle="bold"
                android:textColor="#AB47BC"/>
        </LinearLayout>

        <!-- Donald -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <View android:layout_width="4dp" android:layout_height="match_parent"
                android:background="#43A047" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲ " android:textColor="#43A047" android:textSize="13sp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Donald" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Scottish Lowlands  ≥ 610 m" android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="140" android:textSize="13sp" android:textStyle="bold"
                android:textColor="#43A047"/>
        </LinearLayout>

        <!-- Fiona -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <View android:layout_width="4dp" android:layout_height="match_parent"
                android:background="#FF4081" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲ " android:textColor="#FF4081" android:textSize="13sp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Fiona" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Scotland  762 – 914 m  ≥100 m prom." android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="81" android:textSize="13sp" android:textStyle="bold"
                android:textColor="#FF4081"/>
        </LinearLayout>

        <!-- Wainwright -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <View android:layout_width="4dp" android:layout_height="match_parent"
                android:background="#1E88E5" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲ " android:textColor="#1E88E5" android:textSize="13sp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Wainwright" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Lake District  214 fells" android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="214" android:textSize="13sp" android:textStyle="bold"
                android:textColor="#1E88E5"/>
        </LinearLayout>

        <!-- Hewitt -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <View android:layout_width="4dp" android:layout_height="match_parent"
                android:background="#00ACC1" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲ " android:textColor="#00ACC1" android:textSize="13sp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hewitt" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="England &amp; Wales  ≥ 610 m" android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Island -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <View android:layout_width="4dp" android:layout_height="match_parent"
                android:background="#26A69A" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲ " android:textColor="#26A69A" android:textSize="13sp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Island" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Scottish island summits" android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Sub 2000 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical">
            <View android:layout_width="4dp" android:layout_height="match_parent"
                android:background="#FFD600" android:layout_marginEnd="14dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲ " android:textColor="#FFD600" android:textSize="13sp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sub 2000" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/ob_headline"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Scotland  ≥ 500 m, named" android:textSize="10sp"
                    android:textColor="@color/ob_subtitle"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
