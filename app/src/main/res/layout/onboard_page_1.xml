<?xml version="1.0" encoding="utf-8"?>
<!-- Page 1: Discover Scotland's peaks -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Illustration -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="55"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Decorative mountain range -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_gravity="bottom"
            android:src="@drawable/ic_onboard_mountains"
            android:scaleType="fitXY"
            android:alpha="0.6"/>

        <!-- Main map card, tilted -3° -->
        <androidx.cardview.widget.CardView
            android:layout_width="240dp"
            android:layout_height="175dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:rotation="-3"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/ob_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Search bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:background="@color/ob_search_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Search mountains or areas"
                        android:textSize="11sp"
                        android:textColor="#8A8680"/>
                </LinearLayout>

                <!-- Map with summit markers -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/ob_map_bg">

                    <LinearLayout
                        android:id="@+id/m1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:layout_marginStart="18dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="▲" android:textColor="@color/nav_orange" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ben Nevis" android:textSize="7sp" android:textColor="#333333"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="95dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="▲" android:textColor="@color/nav_orange" android:textSize="11sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Braeriach" android:textSize="7sp" android:textColor="#333333"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="18dp"
                        android:layout_marginStart="168dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="▲" android:textColor="@color/nav_orange" android:textSize="10sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ben Lawers" android:textSize="6sp" android:textColor="#333333"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="@color/nav_orange" android:textSize="9sp"
                        android:layout_marginTop="52dp" android:layout_marginStart="55dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="@color/nav_orange" android:textSize="8sp"
                        android:layout_marginTop="42dp" android:layout_marginStart="138dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="@color/nav_orange" android:textSize="9sp"
                        android:layout_marginTop="65dp" android:layout_marginStart="195dp"/>

                </RelativeLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Floating hill info card, tilted +4° -->
        <androidx.cardview.widget.CardView
            android:layout_width="190dp"
            android:layout_height="52dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="18dp"
            android:rotation="4"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/ob_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▲"
                    android:textColor="@color/nav_orange"
                    android:textSize="20sp"
                    android:layout_marginEnd="8dp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ben Nevis"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/ob_headline"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Munro · 1,345 m"
                        android:textSize="10sp"
                        android:textColor="@color/ob_subtitle"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <!-- Text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="45"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Discover Scotland's peaks"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"
            android:lineSpacingMultiplier="1.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="800+ Munros, Corbetts, Grahams and more — all marked on the map and ready to explore"
            android:textSize="15sp"
            android:textColor="@color/ob_subtitle"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

</LinearLayout>
