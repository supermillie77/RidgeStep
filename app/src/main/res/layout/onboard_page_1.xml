<?xml version="1.0" encoding="utf-8"?>
<!-- Page 1: Discover Scotland's peaks (colour-coded by category) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Illustration -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="55"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Decorative mountain range -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_gravity="bottom"
            android:src="@drawable/ic_onboard_mountains"
            android:scaleType="fitXY"
            android:alpha="0.6"/>

        <!-- Main map card with colour-coded summit markers, tilted -3° -->
        <androidx.cardview.widget.CardView
            android:layout_width="248dp"
            android:layout_height="185dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:rotation="-3"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/ob_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Search bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:background="@color/ob_search_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔍" android:textSize="12sp" android:layout_marginEnd="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Search mountains or areas"
                        android:textSize="11sp" android:textColor="#8A8680"/>
                </LinearLayout>

                <!-- Map with colour-coded markers -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/ob_map_bg">

                    <!-- Munro (orange) -->
                    <LinearLayout android:id="@+id/mm1"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center_horizontal"
                        android:layout_marginTop="10dp" android:layout_marginStart="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="▲" android:textColor="#FF6D00" android:textSize="15sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ben Nevis" android:textSize="7sp" android:textColor="#222"/>
                    </LinearLayout>

                    <!-- Corbett (red) -->
                    <LinearLayout
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center_horizontal"
                        android:layout_marginTop="5dp" android:layout_marginStart="92dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="▲" android:textColor="#E53935" android:textSize="11sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Goat Fell" android:textSize="7sp" android:textColor="#222"/>
                    </LinearLayout>

                    <!-- Wainwright (blue) -->
                    <LinearLayout
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center_horizontal"
                        android:layout_marginTop="16dp" android:layout_marginStart="170dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="▲" android:textColor="#1E88E5" android:textSize="10sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Helvellyn" android:textSize="6sp" android:textColor="#222"/>
                    </LinearLayout>

                    <!-- Donald (green) -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#43A047" android:textSize="11sp"
                        android:layout_marginTop="46dp" android:layout_marginStart="42dp"/>

                    <!-- Fiona (pink) -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#FF4081" android:textSize="9sp"
                        android:layout_marginTop="35dp" android:layout_marginStart="130dp"/>

                    <!-- Hewitt (cyan) -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#00ACC1" android:textSize="10sp"
                        android:layout_marginTop="55dp" android:layout_marginStart="195dp"/>

                    <!-- Island (teal) -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#26A69A" android:textSize="9sp"
                        android:layout_marginTop="62dp" android:layout_marginStart="80dp"/>

                    <!-- Sub 2000 (yellow) -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▲" android:textColor="#FFD600" android:textSize="8sp"
                        android:layout_marginTop="70dp" android:layout_marginStart="150dp"/>

                </RelativeLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Colour legend card, tilted +3.5° -->
        <androidx.cardview.widget.CardView
            android:layout_width="230dp"
            android:layout_height="60dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="14dp"
            android:rotation="3.5"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/ob_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <!-- Row 1 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="▲ Munro"
                        android:textColor="#FF6D00" android:textSize="9.5sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="▲ Corbett"
                        android:textColor="#E53935" android:textSize="9.5sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="▲ Wainwright"
                        android:textColor="#1E88E5" android:textSize="9.5sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="▲ Donald"
                        android:textColor="#43A047" android:textSize="9.5sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="▲ Fiona"
                        android:textColor="#FF4081" android:textSize="9.5sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="▲ Island"
                        android:textColor="#26A69A" android:textSize="9.5sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <!-- Text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="45"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore Britain's hills"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"
            android:lineSpacingMultiplier="1.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="2,700+ summits across 9 categories — from Scottish Munros to Lake District Wainwrights, each shown in its own colour"
            android:textSize="15sp"
            android:textColor="@color/ob_subtitle"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

</LinearLayout>
