<?xml version="1.0" encoding="utf-8"?>
<!-- Page 1: Britain's hills — pyramid of category triangles -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ob_background">

    <!-- Hero: mountain built from category triangles (60%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="60"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="24dp">

        <!-- Apex: Munro -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▲"
            android:textColor="#FF6D00"
            android:textSize="72sp"
            android:lineSpacingExtra="-8dp"/>

        <!-- Row 2: Corbett · Graham -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="-10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲" android:textColor="#E53935" android:textSize="50sp"
                android:paddingEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲" android:textColor="#AB47BC" android:textSize="50sp"
                android:paddingStart="8dp"/>
        </LinearLayout>

        <!-- Row 3: Donald · Fiona · Wainwright -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="-8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲" android:textColor="#43A047" android:textSize="34sp"
                android:paddingEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲" android:textColor="#FF4081" android:textSize="34sp"
                android:paddingStart="4dp" android:paddingEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲" android:textColor="#1E88E5" android:textSize="34sp"
                android:paddingStart="4dp"/>
        </LinearLayout>

        <!-- Row 4: Hewitt · Sub 2000 · Island -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="-6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲" android:textColor="#00ACC1" android:textSize="22sp"
                android:paddingEnd="3dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲" android:textColor="#FFD600" android:textSize="22sp"
                android:paddingStart="3dp" android:paddingEnd="3dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲" android:textColor="#26A69A" android:textSize="22sp"
                android:paddingStart="3dp"/>
        </LinearLayout>

        <!-- Category count strip -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="282 Munros  ·  222 Corbetts  ·  214 Wainwrights"
            android:textSize="11sp"
            android:textColor="@color/ob_subtitle"
            android:letterSpacing="0.04"/>

    </LinearLayout>

    <!-- Text (40%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="40"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="20dp">

        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:background="#FF6B35"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Britain's hills,\nmapped and ready"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/ob_headline"
            android:lineSpacingMultiplier="1.15"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="2,700+ summits across 9 categories — each shown in its own colour so you always know what you're looking at"
            android:textSize="14sp"
            android:textColor="@color/ob_subtitle"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

</LinearLayout>
