<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup rules for API 30 and below.
  The last_location preference contains the device's most-recent GPS coordinates
  and must not be included in cloud backups or device transfers.
  The walk_log preference holds the user's hill-completion records and is
  intentionally included so it survives device changes.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="last_location.xml"/>
</full-backup-content>
