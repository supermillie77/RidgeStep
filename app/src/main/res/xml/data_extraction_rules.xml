<?xml version="1.0" encoding="utf-8"?>
<!--
  Data-extraction rules for API 31+.
  last_location holds the device's most-recent GPS fix and is excluded from
  both cloud backup and device-to-device transfer.
  walk_log (completed hills) is included so it survives device changes.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="last_location.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="last_location.xml"/>
    </device-transfer>
</data-extraction-rules>
